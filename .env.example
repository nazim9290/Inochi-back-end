# Inochi Global Education — Backend
# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=8080

# PostgreSQL — single connection string (preferred)
DATABASE_URL=postgres://user:password@localhost:5432/inochi

# OR set individual fields and leave DATABASE_URL empty:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=inochi
# PG_PASSWORD=
# PG_DATABASE=inochi

# Set to "true" to allow self-signed SSL certificates (managed Postgres providers)
PG_SSL=false

# Sync the schema on startup (dev only — creates/updates tables to match models).
# In production use migrations instead.
DB_SYNC=true

# JWT auth — use a long random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_secret

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
