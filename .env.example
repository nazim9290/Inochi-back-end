# Inochi Global Education — Backend
# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=8080

# PostgreSQL — single connection string (preferred)
DATABASE_URL=postgres://user:password@localhost:5432/inochi

# OR set individual fields and leave DATABASE_URL empty:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=inochi
# PG_PASSWORD=
# PG_DATABASE=inochi

# Set to "true" to allow self-signed SSL certificates (managed Postgres providers)
PG_SSL=false

# Sync the schema on startup (dev only — creates/updates tables to match models).
# In production use migrations instead.
DB_SYNC=true

# JWT auth — use a long random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_secret

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — used to email contact-form notifications and the admin inbox.
# Works with Gmail (use an App Password), Brevo/SendinBlue, SendGrid, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# `From` header on outgoing mail. Defaults to SMTP_USER if blank.
SMTP_FROM=Inochi Global Education <info@inochieducation.com>
# Where contact-form notifications are sent. Defaults to SMTP_USER if blank.
ADMIN_EMAIL=info@inochieducation.com

# Reply-To for school-outreach emails. All replies to outreach mail land here
# regardless of the SMTP From address. Defaults to inochiedu@gmail.com.
MAIL_REPLY_TO=inochiedu@gmail.com
# Delay (ms) between individual outreach sends to respect SMTP rate limits.
MAIL_SEND_DELAY_MS=250

# Public site URL (used by double-opt-in confirm links in newsletter emails,
# and as the host for IndexNow pings below).
PUBLIC_SITE_URL=https://inochieducation.com

# IndexNow — instantly notify Bing/Yandex/etc. when content is published.
# Public verification key (32-char hex). MUST match the frontend's INDEXNOW_KEY
# (the frontend serves it at /indexnow.txt). Generate once with:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Leave blank to disable IndexNow pings entirely (publishing still works).
INDEXNOW_KEY=
