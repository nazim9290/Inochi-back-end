# Inochi Global Education — Backend
# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=8080

# MongoDB Atlas
DB_USER=your_mongo_user
DB_PASS=your_mongo_password

# JWT auth — use a long random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_secret

# TODO: Cloudinary credentials are currently hardcoded in controllers/userAuth.js.
# Move them here when refactoring auth:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
